# MetaMask Private Key (NEVER share or commit this!)
# To export: MetaMask > Account Details > Show Private Key
PRIVATE_KEY=your_private_key_without_0x_prefix

# Alchemy API Keys (get from https://alchemy.com)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR-API-KEY
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR-API-KEY

# Etherscan API Key for contract verification (get from https://etherscan.io/myapikey)
ETHERSCAN_API_KEY=your_etherscan_api_key

# Multi-sig / Wallet Addresses
OWNER_MULTISIG=0x...
TREASURY_MULTISIG=0x...
TEAM_MULTISIG=0x...
ECOSYSTEM_MULTISIG=0x...
MARKETING_MULTISIG=0x...
SEED_MULTISIG=0x...

# Deployment Options (optional)
DRY_RUN=false
SKIP_VERIFY=false
